#!/usr/bin/env bash
set -euo pipefail

if ! command -v fish >/dev/null 2>&1; then
  exit 0
fi

fish_path="$(command -v fish)"
current_shell="${SHELL:-}"

if [[ "$current_shell" == "$fish_path" ]]; then
  exit 0
fi

if grep -qx "$fish_path" /etc/shells 2>/dev/null; then
  printf '[bootstrap] fish is installed. Set it as your login shell with:\n'
  printf '  chsh -s %q\n' "$fish_path"
else
  printf '[bootstrap] fish is installed at %s but is not listed in /etc/shells.\n' "$fish_path"
  printf '[bootstrap] Add it to /etc/shells, then run:\n'
  printf '  chsh -s %q\n' "$fish_path"
fi
